# Dashboard terpadu (fe) — build PRODUKSI.
# Di-serve di SATU domain (pm2 serve :8094). Tiap modul menarik dari backend dept
# yang berbeda, jadi API-nya diarahkan ke path relatif /be/<dept>; nginx vhost
# domain dashboard yang mem-proxy ke backend lokal masing-masing. Pakai path
# relatif supaya tidak bergantung domain per-dept dan bebas CORS.
#
# Blok nginx yang diperlukan (sesuaikan port dgn `ss -tlnp` bila beda):
#   location /be/keuangan/    { proxy_pass http://127.0.0.1:8084/; }
#   location /be/sales/       { proxy_pass http://127.0.0.1:8085/; }
#   location /be/marketing/   { proxy_pass http://127.0.0.1:8086/; }
#   location /be/perencanaan/ { proxy_pass http://127.0.0.1:8082/; }
#   location /be/sheets/      { proxy_pass http://127.0.0.1:8091/; }  # rekap (sheets-api)
#   location /api/            { proxy_pass http://127.0.0.1:8080/; }  # permit (legalpermit)
#   location / { proxy_pass http://127.0.0.1:8094; }                  # SPA (pm2 serve)

VITE_KEUANGAN_API=/be/keuangan
VITE_SALES_API=/be/sales
VITE_MARKETING_API=/be/marketing
VITE_PERENCANAAN_API=/be/perencanaan
VITE_SHEETS_API=/be/sheets

# Permit (legalpermit) tetap lewat /api (default).
VITE_API_BASE_URL=/api
