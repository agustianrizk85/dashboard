[Unit]
Description=x11vnc server untuk display :99
After=xvfb.service
Requires=xvfb.service

[Service]
# Ganti "user" dengan username VPS Anda
User=user
Environment=DISPLAY=:99
ExecStart=/usr/bin/x11vnc -display :99 -rfbauth /home/user/.vnc/passwd -forever -shared
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
